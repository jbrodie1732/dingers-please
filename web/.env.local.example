# Supabase — anon key for public reads
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service key — server-only (no NEXT_PUBLIC prefix), used by the draft pick API route
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Draft admin PIN — server-only, protects the pick-maker on /draft
ADMIN_PIN=your-secret-pin-here
