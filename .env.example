# Supabase — get these from your project's API settings
SUPABASE_URL=your-supabase-project-url
SUPABASE_SERVICE_KEY=your-service-role-key-here

# iMessage group chat name (must match exactly in Messages.app)
IMESSAGE_GROUP_CHAT=Dingers only

# Watcher tuning (optional — defaults shown)
POLL_INTERVAL_MS=60000
EMPTY_POLL_THRESHOLD=120
